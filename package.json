{
  "name": "uses",
  "description": "What do you use",
  "type": "module",
  "version": "8.0.0",
  "packageManager": "pnpm@10.11.1",
  "author": "Wes Bos",
  "engines": {
    "node": ">= 22.12.0"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/exec": "^3.0.0",
    "@actions/github": "^9.0.0",
    "@cloudflare/vite-plugin": "^1.29.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.91.0",
    "@tanstack/react-router": "^1.167.4",
    "@tanstack/react-start": "^1.166.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "country-emoji": "^1.5.6",
    "d3": "^7.9.0",
    "drizzle-orm": "^0.45.1",
    "fast-glob": "^3.3.3",
    "jimp": "^1.6.0",
    "joi": "^18.0.2",
    "lucide-react": "^0.577.0",
    "ml-kmeans": "^7.0.0",
    "openai": "^6.32.0",
    "p-limit": "^7.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shaders": "^2.4.77",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "turndown": "^7.2.2",
    "umap-js": "^1.4.0",
    "vite-plugin-killer-instincts": "^1.1.0",
    "workers-og": "^0.0.27",
    "zod": "^4.3.6"
  },
  "scripts": {
    "sync:data": "tsx ./scripts/sync-data-json.ts",
    "dev": "pnpm sync:data && vp dev",
    "build": "pnpm sync:data && vp build",
    "preview": "vp preview",
    "deploy": "pnpm build && wrangler deploy",
    "typecheck": "pnpm sync:data && tsc --noEmit",
    "test": "pnpm sync:data && vp test run",
    "readme": "node ./scripts/populate-readme.js",
    "scrape": "tsx ./scripts/scrape-uses-to-d1.ts",
    "discover": "tsx --env-file .env ./scripts/discover-tags.ts",
    "canonicalize": "tsx ./scripts/canonicalize-tags.ts",
    "extract": "tsx --env-file .env ./scripts/extract-items.ts",
    "review": "tsx ./scripts/review-extraction.ts",
    "reclassify": "tsx --env-file .env ./scripts/reclassify.ts",
    "merge-dupes": "tsx ./scripts/merge-duplicates.ts",
    "vectorize": "tsx --env-file .env ./scripts/vectorize-profiles.ts",
    "site:tools:list": "tsx ./scripts/site-management-cli.ts list",
    "site:tools:call": "tsx ./scripts/site-management-cli.ts call",
    "generate:tag-metadata": "tsx ./scripts/generate-tag-metadata.ts",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply uses-tech-scrapes --local",
    "db:migrate:remote": "wrangler d1 migrations apply uses-tech-scrapes --remote",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/d3": "^7.4.3",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^6.0.1",
    "better-sqlite3": "^12.8.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
    "wrangler": "^4.75.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ],
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    },
    "peerDependencyRules": {
      "allowAny": [
        "vite",
        "vitest"
      ]
    }
  }
}
