{
  "name": "uses",
  "description": "What do you use",
  "version": "8.0.0",
  "packageManager": "pnpm@10.11.1",
  "author": "Wes Bos",
  "engines": {
    "node": ">= 22.12.0"
  },
  "dependencies": {
    "@actions/core": "^1.10.0",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^5.1.1",
    "@cloudflare/vite-plugin": "^1.25.6",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-router": "^1.163.2",
    "@tanstack/react-start": "^1.163.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "country-emoji": "^1.5.6",
    "fast-glob": "^3.3.3",
    "joi": "^17.8.1",
    "lucide-react": "^0.577.0",
    "openai": "^6.25.0",
    "p-limit": "^7.3.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "turndown": "^7.2.2",
    "vite-plugin-killer-instincts": "^1.0.0",
    "zod": "^4.1.11"
  },
  "scripts": {
    "sync:data": "tsx ./scripts/sync-data-json.ts",
    "dev": "pnpm sync:data && vite dev",
    "build": "pnpm sync:data && vite build",
    "preview": "vite preview",
    "deploy": "pnpm build && wrangler deploy",
    "typecheck": "pnpm sync:data && tsc --noEmit",
    "test": "pnpm sync:data && vitest run",
    "readme": "node ./scripts/populate-readme.js",
    "cull": "tsx ./scripts/cull-invalid-uses.ts",
    "scrape": "tsx ./scripts/scrape-uses-to-d1.ts",
    "discover": "tsx --env-file .env ./scripts/discover-categories.ts",
    "canonicalize": "tsx ./scripts/canonicalize-tags.ts",
    "extract": "tsx --env-file .env ./scripts/extract-items.ts",
    "review": "tsx ./scripts/review-extraction.ts",
    "reclassify": "tsx --env-file .env ./scripts/reclassify.ts",
    "generate:tag-metadata": "tsx ./scripts/generate-tag-metadata.ts"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^8.34.0",
    "eslint-config-wesbos": "^3.2.3",
    "husky": "^8.0.3",
    "lint-staged": "^13.1.2",
    "postcss": "^8.4.21",
    "prettier": "^2.8.4",
    "tsx": "^4.20.5",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.2",
    "vite": "^7.1.12",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4",
    "wrangler": "^4.69.0"
  },
  "lint-staged": {
    "src/data.js": [
      "eslint --fix",
      "git add"
    ]
  }
}
